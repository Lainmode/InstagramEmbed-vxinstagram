@using InstagramEmbed.Application.Models
@using InstagramEmbed.Controllers
@model string[]
@{
    Layout = null;
    string contentUrl = Model[0];
    string? thumbnailUrl = Model[1];
    string igUrl = Model[2];
    bool isPhoto = ViewBag.IsPhoto;
    bool isTelegram = Context.Request.Headers.UserAgent.ToString()
                               .Contains("TelegramBot", StringComparison.OrdinalIgnoreCase);

    string cacheId = ViewBag.PostId ?? "";
    int order = ViewBag.Order ?? 0;
    var baseUrl = $"https://{Context.Request.Host}";

    if (!isPhoto && !contentUrl.EndsWith(".mp4", StringComparison.OrdinalIgnoreCase))
        contentUrl = $"{contentUrl.TrimEnd('/')}.mp4";

    CachedPost? post = ViewBag.Post as CachedPost;
    int width = post?.Width > 0 ? post!.Width : 720;
    int height = post?.Height > 0 ? post!.Height : 1280;

    if (width > 1920 || height > 1920) { width /= 2; height /= 2; }
    if (width < 400 && height < 400) { width *= 2; height *= 2; }

    List<CachedMedia> files = ViewBag.Files as List<CachedMedia> ?? [];
    bool isMultiMedia = files.Count > 1;

    // d.vx → expose caption/author in embed; vx → anonymous
    bool showDetails = Context.Request.Host.Host.StartsWith("d.", StringComparison.OrdinalIgnoreCase);
    string? caption = showDetails ? post?.Caption : null;
    string? username = showDetails ? post?.AuthorUsername : null;
    string? fullName = showDetails ? post?.AuthorName : null;
    string trackName = post?.TrackName ?? "vxinstagram";

    string oembedDesc = isPhoto ? "" : Uri.EscapeDataString(caption ?? "");
    string likesComments = showDetails && (post?.Likes > 0 || post?.Comments > 0)
        ? $" ❤️ {post?.Likes} 💬 {post?.Comments}" : "";


    string activityPayload = $"{cacheId}&{order}&{igUrl}";
    string activityContext = Base64Url.Encode(System.Text.Encoding.UTF8.GetBytes(activityPayload));


    bool emitActivityLink = isMultiMedia;
    string? maybeDonate = ViewBag.MaybeDonate;
}

@if (isTelegram)
{

    <!DOCTYPE html>
    <html>
    <head>
        <meta property="og:type" content="video.other" />
        <meta property="og:title" content="vxinstagram" />
        <meta property="og:image" content="@contentUrl" />

        <meta property="og:video" content="@contentUrl" />
        <meta property="og:video:secure_url" content="@contentUrl" />
        <meta property="og:video:type" content="video/mp4" />
        <meta property="og:video:width" content="720" />
        <meta property="og:video:height" content="1280" />
    </head>
    <body>
    </body>
    </html>
}
else
{
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

        @* Favicon: music note icon for reels with a track *@
        @if (trackName == "vxinstagram")
        {
            <link href="~/favicon.png" rel="icon" type="image/png" sizes="any">
            <link href="~/favicon-32x32.png" rel="icon" type="image/png" sizes="32x32">
            <link href="~/favicon-16x16.png" rel="icon" type="image/png" sizes="16x16">
        }
        else
        {
            <link href="~/favicon-note.png" rel="icon" type="image/png" sizes="any">
            <link href="~/favicon-note-32x32.png" rel="icon" type="image/png" sizes="32x32">
            <link href="~/favicon-note-16x16.png" rel="icon" type="image/png" sizes="16x16">
        }

        @* ── Open Graph / Twitter card ── *@
        @if (isPhoto)
        {
            <meta property="og:image" content="@contentUrl" />
            <meta name="twitter:card" content="summary_large_image" />
            <meta name="twitter:image" content="@contentUrl" />
            @if (caption != null)
            {
                <meta property="og:description" content="@caption" />
            }
        }
        else
        {
            <meta property="og:type" content="video.other" />
            <meta property="og:video" content="@contentUrl" />
            <meta property="og:video:secure_url" content="@contentUrl" />
            <meta property="og:video:type" content="video/mp4" />
            <meta property="og:video:width" content="@width" />
            <meta property="og:video:height" content="@height" />
            <meta name="twitter:card" content="player" />
            if (isTelegram && thumbnailUrl != null)
            {
                <meta property="og:image" content="@thumbnailUrl" />
            }
            <meta name="twitter:player:stream" content="@contentUrl" />
            <meta name="twitter:player:stream:content_type" content="video/mp4" />
            <meta name="twitter:player:width" content="@width" />
            <meta name="twitter:player:height" content="@height" />
            @if (!isTelegram)
            {
                <meta name="twitter:player" content="@igUrl" />
            }
        }

        <meta property="og:site_name" content="@trackName" />
        <meta property="theme-color" content="#eb4034" />
        <meta property="og:url" content="@igUrl" />
        <link rel="canonical" href="@igUrl" />

        @if (caption != null && username != null)
        {
            <meta property="og:title" content="@($"{fullName} (@{username})")" />
            <meta property="og:description" content="@caption" />
            <meta property="twitter:title" content="@($"{fullName} (@{username})")" />
            <meta property="twitter:site" content="@username" />
            <meta property="twitter:creator" content="@username" />
        }
        else if (isTelegram)
        {
            <meta property="og:title" content="vxinstagram" />
            <meta property="twitter:title" content="vxinstagram" />
        }


        @if (emitActivityLink || maybeDonate != null)
        {
            <link rel="alternate" type="application/json+oembed"
                  href="@(baseUrl)/oembed?username=@(username ?? "instagram")&desc=@oembedDesc&likescomments=@Uri.EscapeDataString(likesComments)&donateMessage=@maybeDonate" />
        }
        @* activity+json only for multi-media posts — triggers Discord's image grid *@
        @if (emitActivityLink || isTelegram)
        {
            <link rel="alternate" type="application/activity+json"
                  href="@(baseUrl)/users/username/statuses/@activityContext" />
        }

        <title>vxinstagram</title>
    </head>
    <body class="bg-dark text-light">

        <div class="d-flex border-bottom border-secondary p-4 align-items-center justify-content-between shadow">
            <div>
                <div class="text-secondary">
                    InstagramEmbed by
                    <a href="https://github.com/Lainmode/InstagramEmbedForDiscord" target="_blank">Lainmode</a>
                </div>
            </div>
            <a target="_blank" href="https://www.buymeacoffee.com/alsauce">
                <img class="mb-2" style="height:2.5rem"
                     src="https://img.buymeacoffee.com/button-api/?text=Buy+me+a+coffee&emoji=☕&slug=alsauce&button_colour=954b89&font_colour=ffffff&font_family=Cookie&outline_colour=ffffff&coffee_colour=FFDD00" />
            </a>
        </div>

        <div class="container mt-5" style=" max-width:860px">
            <div class="card border-0 shadow mb-4" style="background:#111;">
                <div class="card-body  border border-warning rounded-3 border-5">
                    <h4 class="text-warning">Please read</h4>
                    <h6>
                        vxInstagram runs on my private server. Handling hundreds of thousands of monthly requests is challenging to maintain as a college student. To keep the service alive, please consider donating if you have the means. Thank you.
                    </h6>

                    <h5 class="mb-0 fw-bolder text-warning">5€ raised this month</h5>
                    <h6 class="text-muted">Out of 100€</h6>
                    <div class="progress rounded-pill border-0 mb-3" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" style="height:1rem;">
                        <div class="progress-bar bg-warning border-0 d-flex align-items-center justify-content-center" style="width: 5%">
                        </div>
                    </div>

                    <a class="btn btn-warning rounded-pill fw-bold" href="https://buymeacoffee.com/alsauce" target="_blank">Buy Me A Coffee</a>

                </div>
            </div>
        </div>

        <div class="row g-4 align-items-start w-100 justify-content-center mx-auto p-4">
            @foreach (var item in files)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card border-secondary shadow rounded-3 bg-dark text-light overflow-hidden">
                        @if (item.MediaType == "video")
                        {
                            <video class="w-100" style="aspect-ratio:5/6; object-fit:cover;" controls>
                                <source src="@item.Url" type="video/mp4" />
                                Your browser does not support the video tag.
                            </video>
                        }
                        else
                        {
                            <img src="@item.Url" class="w-100"
                                 style="aspect-ratio:5/6; object-fit:cover;" alt="Instagram post" />
                        }
                        <div class="d-flex flex-column gap-2 p-3">
                            <a class="btn btn-success" href="@item.Url" download>Download</a>
                            <a class="btn btn-primary" href="@igUrl" target="_blank">View Original</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </body>
    </html>
}